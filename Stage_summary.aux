\@writefile{lof}{\contentsline {figure}{\numberline {3.2}{\ignorespaces Exemple d'événements récents utilisés pour isoler une portion plus cohérente du mouvement de la balle.}}{9}{figure.3.2}\protected@file@percent }
\newlabel{fig:evenements-recents-circle}{{3.2}{9}{Exemple d'événements récents utilisés pour isoler une portion plus cohérente du mouvement de la balle}{figure.3.2}{}}
\@writefile{toc}{\contentsline {section}{\numberline {3.4}Ajustement du cercle et validation}{9}{section.3.4}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3.3}{\ignorespaces Principe de validation par symétrie des polarités: les événements positifs et négatifs doivent former deux directions moyennes opposées autour du centre du cercle candidat.}}{10}{figure.3.3}\protected@file@percent }
\newlabel{fig:symetrie-polarites-circle}{{3.3}{10}{Principe de validation par symétrie des polarités: les événements positifs et négatifs doivent former deux directions moyennes opposées autour du centre du cercle candidat}{figure.3.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3.4}{\ignorespaces Sortie 2D de l'algorithme. La partie gauche montre les événements bruts, tandis que la partie droite montre les clusters, le cercle retenu et la trajectoire image. La flèche verte indique l'estimation de la direction de la balle; cette direction est stabilisée par la validation de polarité et de symétrie du cluster.}}{11}{figure.3.4}\protected@file@percent }
\newlabel{fig:sortie-algo-2d}{{3.4}{11}{Sortie 2D de l'algorithme. La partie gauche montre les événements bruts, tandis que la partie droite montre les clusters, le cercle retenu et la trajectoire image. La flèche verte indique l'estimation de la direction de la balle; cette direction est stabilisée par la validation de polarité et de symétrie du cluster}{figure.3.4}{}}
