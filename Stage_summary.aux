\@writefile{lot}{\contentsline {table}{\numberline {3.1}{\ignorespaces Sensibilité de la profondeur pour la caméra réelle, avec \(f_x \approx 761~\text  {px}\) et \(R = 20~\text  {mm}\).}}{14}{table.3.1}\protected@file@percent }
\newlabel{tab:depth-sensitivity}{{3.1}{14}{Sensibilité de la profondeur pour la caméra réelle, avec \(f_x \approx 761~\text {px}\) et \(R = 20~\text {mm}\)}{table.3.1}{}}
\@writefile{toc}{\contentsline {section}{\numberline {3.8}Décalage du plan estimé à haute vitesse}{14}{section.3.8}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3.6}{\ignorespaces Exemples de décalage de la trajectoire 3D estimée lorsque la balle est rapide. Les points estimés ne suivent pas toujours le plan vertical attendu pour le lancer.}}{14}{figure.3.6}\protected@file@percent }
\newlabel{fig:circle-fitting-3d-plane-bias}{{3.6}{14}{Exemples de décalage de la trajectoire 3D estimée lorsque la balle est rapide. Les points estimés ne suivent pas toujours le plan vertical attendu pour le lancer}{figure.3.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3.7}{\ignorespaces Analyse du biais de profondeur. En haut à droite, la vue de dessus montre le décalage des estimations par rapport au plan attendu; le graphique adjacent trace la distance orthogonale à ce plan en fonction de la vitesse estimée dans le plan caméra. La tendance linéaire suggère une proportionnalité entre vitesse et erreur de profondeur.}}{16}{figure.3.7}\protected@file@percent }
\newlabel{fig:circle-fitting-speed-depth-bias}{{3.7}{16}{Analyse du biais de profondeur. En haut à droite, la vue de dessus montre le décalage des estimations par rapport au plan attendu; le graphique adjacent trace la distance orthogonale à ce plan en fonction de la vitesse estimée dans le plan caméra. La tendance linéaire suggère une proportionnalité entre vitesse et erreur de profondeur}{figure.3.7}{}}
\@writefile{toc}{\contentsline {section}{\numberline {3.9}Conclusion sur la méthode par circle fitting}{16}{section.3.9}\protected@file@percent }
